generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// SHARED MODELS (must match investor portal exactly)
// ============================================

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  password_hash String
  full_name     String?
  role          String      @default("user")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  investor      Investor?   @relation("InvestorUser")
  mcc_session   MccSession?
}

model Investor {
  id                 String         @id @default(cuid())
  first_name         String
  last_name          String
  name               String
  email              String         @unique
  phone              String?
  company            String?
  notes              String?
  user_id            String?        @unique
  user               User?          @relation("InvestorUser", fields: [user_id], references: [id])
  has_login          Boolean        @default(false)
  invite_token       String?        @unique
  invite_sent_at     DateTime?
  invite_accepted_at DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  investments        Investment[]
  payments           Payment[]
  notifications      Notification[]
  documents          Document[]
  reinvestments      Reinvestment[]
}

model Slate {
  id            String       @id @default(cuid())
  name          String
  description   String?
  status        String       @default("planning")
  budget        Float        @default(0)
  start_date    DateTime?
  end_date      DateTime?
  target_return Float?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  films         Film[]
  investments   Investment[]
}

model Film {
  id              String         @id @default(cuid())
  title           String
  slate_id        String
  slate           Slate          @relation(fields: [slate_id], references: [id])
  budget          Float          @default(0)
  status          String         @default("development")
  genre           String?
  description     String?
  release_date    DateTime?
  total_revenue   Float          @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  revenue_entries RevenueEntry[]
  expenses        Expense[]
}

model Investment {
  id                    String   @id @default(cuid())
  investor_id           String
  investor              Investor @relation(fields: [investor_id], references: [id])
  slate_id              String
  slate                 Slate    @relation(fields: [slate_id], references: [id])
  amount                Float    @default(0)
  ownership_percentage  Float    @default(0)
  rollover_amount       Float    @default(0)
  new_cash_amount       Float    @default(0)
  total_investment      Float    @default(0)
  source_investment_id  String?
  is_reinvestment       Boolean  @default(false)
  reinvested_amount     Float    @default(0)
  recouped_amount       Float    @default(0)
  total_returned        Float    @default(0)
  current_stage         String   @default("invested")
  recoupment_percentage Float    @default(0)
  premium_target        Float    @default(0)
  premium_paid          Float    @default(0)
  backend_percentage    Float    @default(0)
  backend_paid          Float    @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model RevenueEntry {
  id          String   @id @default(cuid())
  film_id     String
  film        Film     @relation(fields: [film_id], references: [id])
  amount      Float
  source      String?
  date        DateTime
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Expense {
  id          String   @id @default(cuid())
  film_id     String
  film        Film     @relation(fields: [film_id], references: [id])
  amount      Float
  category    String?
  description String?
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payment {
  id          String   @id @default(cuid())
  investor_id String
  investor    Investor @relation(fields: [investor_id], references: [id])
  amount      Float
  type        String?
  status      String   @default("pending")
  date        DateTime
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id          String   @id @default(cuid())
  investor_id String
  investor    Investor @relation(fields: [investor_id], references: [id])
  title       String
  message     String
  read        Boolean  @default(false)
  type        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Document {
  id          String    @id @default(cuid())
  investor_id String?
  investor    Investor? @relation(fields: [investor_id], references: [id])
  title       String
  file_url    String?
  file_type   String?
  description String?
  is_global   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Reinvestment {
  id                 String    @id @default(cuid())
  investor_id        String
  investor           Investor  @relation(fields: [investor_id], references: [id])
  amount             Float
  from_investment_id String?
  to_slate_id        String?
  status             String    @default("pending")
  date               DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

// ============================================
// NEW MCC MODELS
// ============================================

model MccSession {
  id                   String    @id @default(cuid())
  user_id              String    @unique
  google_access_token  String?
  google_refresh_token String?
  google_token_expiry  DateTime?
  google_email         String?
  cliq_webhook_url     String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [user_id], references: [id])
}

model EmailDigest {
  id               String   @id @default(cuid())
  gmail_id         String   @unique
  thread_id        String?
  from_address     String
  from_name        String?
  subject          String
  snippet          String?
  received_at      DateTime
  is_important     Boolean  @default(false)
  is_urgent        Boolean  @default(false)
  category         String?
  ai_summary       String?
  ai_action_items  String?
  ai_confidence    Float?
  read_in_mcc      Boolean  @default(false)
  dismissed        Boolean  @default(false)
  raw_body_preview String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([is_important, dismissed])
  @@index([received_at])
  @@index([category])
}

model CalendarEvent {
  id              String   @id @default(cuid())
  google_event_id String   @unique
  title           String
  description     String?
  start_time      DateTime
  end_time        DateTime
  location        String?
  meet_link       String?
  attendees       String?
  is_important    Boolean  @default(false)
  ai_prep_notes   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([start_time])
}

model MccAlert {
  id           String    @id @default(cuid())
  type         String
  severity     String    @default("info")
  title        String
  message      String
  source_type  String?
  source_id    String?
  acknowledged Boolean   @default(false)
  sent_to_cliq Boolean   @default(false)
  cliq_sent_at DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([acknowledged, severity])
  @@index([createdAt])
}

model MccTask {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("pending")
  priority    String    @default("medium")
  due_date    DateTime?
  source_type String?
  source_id   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, priority])
}

model PollLog {
  id               String   @id @default(cuid())
  poll_type        String
  status           String
  emails_processed Int      @default(0)
  events_processed Int      @default(0)
  alerts_created   Int      @default(0)
  error_message    String?
  duration_ms      Int?
  createdAt        DateTime @default(now())
}
