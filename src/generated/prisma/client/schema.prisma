generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

// ============================================
// EXISTING MODELS (from investor portal)
// ============================================

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  password_hash String
  full_name     String
  role          String      @default("investor")
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt
  investor      Investor?
  mcc_session   MccSession?

  @@map("users")
  @@schema("public")
}

model Investor {
  id             String       @id @default(cuid())
  name           String
  email          String       @unique
  phone          String?
  company        String?
  user_id        String?      @unique
  invite_sent_at DateTime?
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt
  user           User?        @relation(fields: [user_id], references: [id])
  investments    Investment[]
  payments       Payment[]
  documents      Document[]

  @@map("investors")
  @@schema("public")
}

model Slate {
  id          String       @id @default(cuid())
  name        String
  description String?
  budget      Float
  start_date  DateTime?
  end_date    DateTime?
  status      String       @default("active")
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  films       Film[]
  investments Investment[]
  expenses    Expense[]

  @@map("slates")
  @@schema("public")
}

model Film {
  id              String         @id @default(cuid())
  title           String
  description     String?
  genre           String?
  status          String         @default("development")
  budget          Float          @default(0)
  revenue         Float          @default(0)
  poster_url      String?
  trailer_url     String?
  release_date    DateTime?
  slate_id        String?
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt
  slate           Slate?         @relation(fields: [slate_id], references: [id])
  revenue_entries RevenueEntry[]
  expenses        Expense[]

  @@map("films")
  @@schema("public")
}

model Investment {
  id          String   @id @default(cuid())
  investor_id String
  slate_id    String
  amount      Float
  date        DateTime
  status      String   @default("pending")
  notes       String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  investor    Investor @relation(fields: [investor_id], references: [id])
  slate       Slate    @relation(fields: [slate_id], references: [id])

  @@map("investments")
  @@schema("public")
}

model Payment {
  id          String    @id @default(cuid())
  investor_id String?
  amount      Float
  date        DateTime
  type        String
  status      String    @default("pending")
  description String?
  reference   String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  investor    Investor? @relation(fields: [investor_id], references: [id])

  @@map("payments")
  @@schema("public")
}

model RevenueEntry {
  id          String   @id @default(cuid())
  film_id     String?
  amount      Float
  source      String
  date        DateTime
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  film        Film?    @relation(fields: [film_id], references: [id])

  @@map("revenue_entries")
  @@schema("public")
}

model Expense {
  id          String   @id @default(cuid())
  film_id     String?
  slate_id    String?
  amount      Float
  category    String
  date        DateTime
  description String?
  vendor      String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  film        Film?    @relation(fields: [film_id], references: [id])
  slate       Slate?   @relation(fields: [slate_id], references: [id])

  @@map("expenses")
  @@schema("public")
}

model Document {
  id          String    @id @default(cuid())
  investor_id String?
  name        String
  file_url    String
  doc_type    String
  description String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  investor    Investor? @relation(fields: [investor_id], references: [id])

  @@map("documents")
  @@schema("public")
}

model Notification {
  id         String   @id @default(cuid())
  user_email String
  title      String
  message    String
  type       String
  read       Boolean  @default(false)
  link       String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("notifications")
  @@schema("public")
}

// ============================================
// NEW MCC MODELS
// ============================================

model MccSession {
  id                   String    @id @default(cuid())
  user_id              String    @unique
  google_access_token  String?
  google_refresh_token String?
  google_token_expiry  DateTime?
  google_email         String?
  cliq_webhook_url     String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [user_id], references: [id])

  @@map("mcc_sessions")
  @@schema("public")
}

model EmailDigest {
  id               String   @id @default(cuid())
  gmail_id         String   @unique
  thread_id        String?
  from_address     String
  from_name        String?
  subject          String
  snippet          String?
  received_at      DateTime
  is_important     Boolean  @default(false)
  is_urgent        Boolean  @default(false)
  category         String?
  ai_summary       String?
  ai_action_items  String?
  ai_confidence    Float?
  read_in_mcc      Boolean  @default(false)
  dismissed        Boolean  @default(false)
  raw_body_preview String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([is_important, dismissed])
  @@index([received_at])
  @@index([category])
  @@map("email_digests")
  @@schema("public")
}

model CalendarEvent {
  id              String   @id @default(cuid())
  google_event_id String   @unique
  title           String
  description     String?
  start_time      DateTime
  end_time        DateTime
  location        String?
  meet_link       String?
  attendees       String?
  is_important    Boolean  @default(false)
  ai_prep_notes   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([start_time])
  @@map("calendar_events")
  @@schema("public")
}

model MccAlert {
  id           String    @id @default(cuid())
  type         String
  severity     String    @default("info")
  title        String
  message      String
  source_type  String?
  source_id    String?
  acknowledged Boolean   @default(false)
  sent_to_cliq Boolean   @default(false)
  cliq_sent_at DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([acknowledged, severity])
  @@index([createdAt])
  @@map("mcc_alerts")
  @@schema("public")
}

model MccTask {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("pending")
  priority    String    @default("medium")
  due_date    DateTime?
  source_type String?
  source_id   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, priority])
  @@map("mcc_tasks")
  @@schema("public")
}

model PollLog {
  id               String   @id @default(cuid())
  poll_type        String
  status           String
  emails_processed Int      @default(0)
  events_processed Int      @default(0)
  alerts_created   Int      @default(0)
  error_message    String?
  duration_ms      Int?
  createdAt        DateTime @default(now())

  @@map("poll_logs")
  @@schema("public")
}
